modules = ["python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Simulation"

[[workflows.workflow]]
name = "Run Simulation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m parimutuel_sim.cli --seed 1234 --n-trials 100"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["python", "-m", "parimutuel_sim.cli", "--seed", "1234"]
